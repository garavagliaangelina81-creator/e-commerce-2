<link rel="stylesheet" href="/css/index.css">

<main class="home-main">

    <!-- Cuando mostrar el HERO -->
    <% if (!locals.esBusqueda && !locals.esCategoria) { %>
        <section id="hero">
            <div class="contenedor-hero">
                <h2>Ofertas de temporada</h2>
                <a href="/ofertas">
                    <button>Ver más</button>
                </a>
            </div>
        </section>

        <%- include('../partials/categorias') %> <br>
    <% } %>
        
    <!-- mostrar productos por categoría -->
    <% if (locals.esCategoria) { %>
        <section class="products-section">
            <h2><%= categoriaActual %></h2>

            <div class="products-grid-filas" id="grilla-todos-productos">
                <% productos.forEach(producto => { %>
                    <%- include('../partials/productCard', {producto}) %>
                <% }) %>
            </div>
        </section>
    <% } %>

    <section class="products-section">
        <h2><%= locals.esBusqueda ? 'Resultados de tu búsqueda' : 'Te puede interesar' %></h2>

        <% if (locals.mensaje) { %>
            <div class="no-results">
                <p><%= mensaje %></p>
            </div>
        <% } %>
        <div class="slider-container">
            <% sugeridos.forEach(producto => { %>
                <%- include('../partials/productCard', {producto}) %>
            <% }) %>
        </div>
    </section>
    
    <% if (!locals.esBusqueda && !locals.esCategoria) { %>
        <section class="products-section highlighted">
            <h2>Los productos más pedidos</h2>
            <div class="slider-container">
                <% destacados.forEach(producto => { %>
                    <%- include('../partials/productCard', {producto}) %>
                <% }) %>
            </div>
        </section>

    <section class="products-section">
            <h2>Todos los productos</h2>
            <div class="products-grid-filas" id="grilla-todos-productos">
                <% todos.forEach((producto, index) => { %>
                    <div class="item-producto <%= index >= 8 ? 'oculto' : '' %>">
                        <%- include('../partials/productCard', {producto}) %>
                    </div>
                <% }) %>
            </div>

            <% if (todos.length > 8) { %>
                <div class="contenedor-ver-mas">
                    <button id="btn-ver-mas" class="btn-secundario">Ver más productos</button>
                </div>
            <% } %>
        </section>

        <%- include('../partials/categorias') %>
    <% } %>


    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const btnVerMas = document.getElementById('btn-ver-mas');
        if (btnVerMas) {
            btnVerMas.addEventListener('click', () => {
                // Buscamos todos los productos que están ocultos
                const productosOcultos = document.querySelectorAll('#grilla-todos-productos .oculto');
                
                // Les quitamos la clase oculto para que aparezcan
                productosOcultos.forEach(producto => {
                    producto.classList.remove('oculto');
                });
                
                // Ocultamos el botón porque ya mostramos todo
                btnVerMas.style.display = 'none';
            });
        }
    });
</script>

</main>
