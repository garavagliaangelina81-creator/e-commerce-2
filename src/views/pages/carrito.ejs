<main>
    <section class="carrito">
        
        <a class="volver" href="/">🡠 Volver</a>
        
        <% if (productos.length != 0) { %>
            <h1>Tu carrito</h1>

            <% productos.forEach(producto => { %>
                <article class= "carrito-item">
                    <div class="carrito-item-info">
                        <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>">
                        <h2><%= producto.nombre %></h2>
                    </div>
                    <div class="carrito-item-acciones">
                        <div class="modificador-cantidad">
                            <a href ="/carrito/sumar/<%= producto.id %>">+</a>
                            <span class="cantidad"><%= producto.cantidad %></span>
                            <a href ="/carrito/restar/<%= producto.id %>">-</a>
                        </div>
                        <div class="precio-y-quitar">
                            <span class="precio"><%= producto.precio * producto.cantidad %> puntos</span>
                            <a class="boton-eliminar" href="/carrito/eliminar/<%= producto.id %>">🗑️</a>
                        </div>
                    </div>

                </article>
            <% }); %>

            <div class="carrito-footer">
                <div class="resumen-caja">
                    <div class="total-fila">
                        <span class="total-etiqueta">Total a pagar:</span>
                        <span class="total-valor"><%= total %> puntos</span>
                    </div>
                    
                    <a href="/checkout" class="boton-finalizar">Finalizar compra</a>
                    
                    <a class="link-vaciar" href="/carrito/vaciar">Vaciar carrito</a>
                </div>
            </div>


            <% } else { %>
                <p id="carrito-vacio" >Tu carrito está vacío.</p>
            <% } %>
        
    </section>
</main>
