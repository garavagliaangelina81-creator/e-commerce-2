<main class="home-main">

    <% if (!locals.esBusqueda) { %>
        <section id="hero">
            <div class="contenedor-hero">
                <h2>Ofertas de temporada</h2>
                <button>Ver más</button>
            </div>
        </section>

        <%- include('../partials/categorias') %> <br>
        <% } %>
        
        <% if (locals.esCategoria) { %>
            <section class="products-section">
                <h2><%= categoriaActual %></h2>

                <div class="products-grid">
                    <% productos.forEach(producto => { %>
                        <%- include('../partials/productCard', {producto}) %>
                    <% }) %>
                </div>
            </section>
        <% } %>

        <section class="products-section">
            <h2><%= locals.esBusqueda ? 'Resultados de tu búsqueda' : 'Te puede interesar' %></h2>

            <% if (locals.mensaje) { %>
                <div class="no-results">
                    <p><%= mensaje %></p>
                </div>
            <% } %>
            <div class="slider-container">
                <% sugeridos.forEach(producto => { %>
                    <%- include('../partials/productCard', {producto}) %>
                <% }) %>
            </div>
        </section>
    
    <% if (!locals.esBusqueda && !locals.esCategoria) { %>
        <section class="products-section highlighted">
            <h2>Los productos más pedidos</h2>
            <div class="slider-container">
                <% destacados.forEach(producto => { %>
                    <%- include('../partials/productCard', {producto}) %>
                <% }) %>
            </div>
        </section>

        <section class="products-section">
            <h2>Todos los productos</h2>
            <div class="products-grid-filas">
                <% todos.forEach(producto => { %>
                    <%- include('../partials/productCard', {producto}) %>
                <% }) %>
            </div>
        </section>

        <%- include('../partials/categorias') %>
    <% } %>
</main>

<style>
    /*
       configuracion de los carruceles (Sugeridos y Destacados)
     */
      .slider-container {
        display: flex;
        gap: 20px;
        padding: 15px 5px;
        overflow-x: auto;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        width: 100%;
    }
    .slider-container::-webkit-scrollbar {
        height: 5px; 
        display: block; 
    }

    .slider-container::-webkit-scrollbar-track {
        background: transparent; 
    }

    .slider-container::-webkit-scrollbar-thumb {
        background: #dcdcdc; 
        border-radius: 10px; 
    }

    /* 4. Efecto por si pasan el mouse por arriba de la barrita */
    .slider-container::-webkit-scrollbar-thumb:hover {
        background: #c1c1c1; /* Se oscurece apenas un poquito al tocarla */
    }

    /* Para que Firefox también la muestre fina y gris */
    .slider-container {
        scrollbar-width: thin;
        scrollbar-color: #dcdcdc transparent;
    }
   

    /*se muestran exactamente 4 productos por fila */
    .products-grid-filas {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px; 
        padding: 20px 5px;
        width: 100%;
    }

    .products-grid-filas .slider-item {
        min-width: unset !important; 
        max-width: unset !important; 
        width: 100%;
    }
    @media (max-width: 850px) {
        .products-grid-filas {
            grid-template-columns: repeat(2, 1fr); 
        }
    }
    @media (max-width: 480px) {
        .products-grid-filas {
            grid-template-columns: 1fr;
        }
    }
</style>
    

