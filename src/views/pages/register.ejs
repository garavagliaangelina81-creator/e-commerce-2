<%- include('../partials/header') %>
<main class="main-auth">
    <div class="ingreso-card">
        <h1>Registro de Usuario</h1>
        <form action="/register" method="post">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombreU" placeholder="Nombre de usuario" required value="<%= locals.oldData ? oldData.nombreU : '' %>" >
            <% if (locals.errors && errors.nombreU) { %>
                <p style="color: red;" class="error-msg"><%= errors.nombreU.msg %></p>
            <% } %>
            <label for="apellido">Apellido</label>
            <input type="text" id="apellido" name="apellido" placeholder="Apellido" required value="<%= locals.oldData ? oldData.apellido : '' %>">
            <% if (locals.errors && errors.apellido) { %>
                <p style="color: red;" class="error-msg"><%= errors.apellido.msg %></p>
            <% } %>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="ejemplo@email.com" required value="<%= locals.oldData ? oldData.email : '' %>">
            <% if (locals.errors && errors.email) { %>
                <p style="color: red;" class="error-msg"><%= errors.email.msg %></p>
            <% } %>
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="*********" required>
            <% if (locals.errors && errors.password) { %>
                <p style="color: red;" class="error-msg"><%= errors.password.msg %></p>
            <% } %>
            <button type="submit">Registrarse</button>
        </form>
        <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>        
    </div>
</main>

<%- include('../partials/footer') %>